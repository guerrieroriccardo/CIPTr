# ── Backend ───────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgres://ciptr:ciptr@localhost:5432/ciptr?sslmode=disable

# HTTP listen port
PORT=8080

# Secret used to sign JWT tokens (if unset, a random one is generated at startup)
JWT_SECRET=change-me-in-production

# Gin framework mode: "debug" (default) or "release"
GIN_MODE=debug

# Base URL encoded in device-label QR codes
LABEL_BASE_URL=https://ciptr.example.com

# ── CLI ───────────────────────────────────────────────────
# Backend API endpoint for the TUI client
CIPTR_API_URL=http://localhost:8080/api/v1
