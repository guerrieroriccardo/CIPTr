# ── Backend ───────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgres://ciptr:ciptr@postgres:5432/ciptr?sslmode=disable # Remove to automatically use the compose postgres
POSTGRES_DB=ciptr
POSTGRES_USER=ciptr
POSTGRES_PASSWORD=ciptr

# HTTP listen port
PORT=8080

# Secret used to sign JWT tokens (if unset, a random one is generated at startup)
JWT_SECRET=change-me-in-production

# Gin framework mode: "debug" (default) or "release"
GIN_MODE=debug

# Base URL encoded in device-label QR codes
LABEL_BASE_URL=https://ciptr.example.com

# Path to logo file inside the container (bind-mounted via docker-compose)
LABEL_LOGO_PATH=/app/logo.png

# Path to logo file on the host (source for the bind mount)
LABEL_LOGO_SRC=./logo.png
